{
  "name": "@teach-everything/api",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/app.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "NODE_ENV=development tsx watch --import ./src/instrumentation.ts src/index.ts",
    "build": "tsup",
    "start": "node --import ./dist/instrumentation.js dist/index.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.8",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.78.0",
    "@opentelemetry/exporter-metrics-otlp-proto": "^0.220.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.220.0",
    "@opentelemetry/sdk-metrics": "^2.9.0",
    "@opentelemetry/sdk-node": "^0.220.0",
    "@teach-everything/observability": "workspace:*",
    "@teach-everything/shared": "workspace:*",
    "hono": "^4.12.29"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsup": "^8.5.1",
    "tsx": "^4.23.0",
    "typescript": "~6.0.3"
  }
}
